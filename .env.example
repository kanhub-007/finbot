# === Execution mode ===
# dry_run: simulate with fake data, no API key needed
# testnet: trade on Hyperliquid testnet
# live:    trade on Hyperliquid mainnet (FINBOT_LIVE_TRADING_ACK required)
FINBOT_MODE=dry_run

# Required for live mode. Set to true only when you intend to trade real funds.
FINBOT_LIVE_TRADING_ACK=false

# === Hyperliquid Authentication (Agent Wallet) ===
# Hyperliquid uses "Agent Wallets" (also called API Wallets) — a dedicated
# private key you authorize to sign trades on behalf of your main account.
# The agent key CANNOT withdraw or transfer funds; it can only place/cancel
# orders and modify positions.
#
# Generate one at: https://app.hyperliquid.xyz/API
#
# IMPORTANT: Agent wallets expire after 90 days (up to 180 if set to MAX).
# When your bot starts getting unauthorized errors, generate a new one.

# Set to false for mainnet, true for testnet (use the matching testnet API page)
FINBOT_HYPERLIQUID_TESTNET=true

# Your Agent Wallet private key (64 hex chars). Required for testnet/live.
# This is NOT your main wallet key — it's the Agent key from the API page.
FINBOT_HYPERLIQUID_PRIVATE_KEY=

# Your MAIN wallet address (0x...). The account whose margin is traded.
# Used for REST queries and websocket auth. The agent key signs; this
# address tells Hyperliquid whose funds to trade with.
FINBOT_HYPERLIQUID_ACCOUNT_ADDRESS=

# Vault address (optional). Set if trading through a vault contract.
FINBOT_HYPERLIQUID_VAULT_ADDRESS=

# === Risk limits ===
# Maximum position notional in USD. Start small, increase gradually.
FINBOT_MAX_POSITION_USD=100

# Maximum daily loss in USD. Bot stops if exceeded.
FINBOT_MAX_DAILY_LOSS_USD=25

# Maximum concurrent open orders.
FINBOT_MAX_OPEN_ORDERS=3

# Maximum leverage allowed per symbol. Orders above this are rejected
# by MaxLeverageGate before reaching the exchange.
FINBOT_MAX_LEVERAGE=20

# Seconds without a candle update before stream is considered stale.
FINBOT_STALE_DATA_SECONDS=120

# === Persistence ===
# SQLite database path. Used for testnet/live (required).
# For dry-run: set to a file path (not :memory:, not the default)
# to persist signals and audit trail across runs.
FINBOT_DATABASE_URL=sqlite:///data/finbot.db
