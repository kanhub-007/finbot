# dry_run | testnet | live
FINBOT_MODE=dry_run

# Required only for live trading. Keep false unless intentionally enabling live.
FINBOT_LIVE_TRADING_ACK=false

# Hyperliquid
FINBOT_HYPERLIQUID_TESTNET=true
FINBOT_HYPERLIQUID_PRIVATE_KEY=
FINBOT_HYPERLIQUID_ACCOUNT_ADDRESS=
FINBOT_HYPERLIQUID_VAULT_ADDRESS=

# Bot defaults
FINBOT_DATABASE_URL=sqlite:///data/finbot.db
FINBOT_MAX_POSITION_USD=100
FINBOT_MAX_DAILY_LOSS_USD=25
FINBOT_MAX_OPEN_ORDERS=3
FINBOT_STALE_DATA_SECONDS=120
